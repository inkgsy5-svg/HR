{
  "expo": {
    "name": "Haciéndolo Real",
    "slug": "hr-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hr-logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/hr-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haciendoloreal.hrapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/hr-logo.png",
        "backgroundColor": "#0F0F1A"
      },
      "package": "com.haciendoloreal.hrapp",
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "http://localhost:3000",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "plugins": ["expo-secure-store"]
  }
}
